{
  "name": "nuxtblog-plugin-reading-time",
  "version": "0.1.5",
  "description": "在文章渲染时自动计算并注入阅读时间提示",
  "author": "nuxtblog",
  "license": "MIT",
  "keywords": [
    "reading-time",
    "ux",
    "nuxtblog-plugin"
  ],
  "private": true,
  "plugin": {
    "title": "阅读时间",
    "icon": "i-tabler-clock",
    "sdkVersion": "0.1.0",
    "trust_level": "official",
    "entry": "dist/index.js",
    "activationEvents": [
      "onEvent:content.*"
    ],
    "capabilities": {},
    "settings": [
      {
        "key": "cn_cpm",
        "label": "中文阅读速度（字/分钟）",
        "type": "number",
        "default": 400,
        "description": "每分钟阅读中文字符数，建议 300–500"
      },
      {
        "key": "en_wpm",
        "label": "英文阅读速度（词/分钟）",
        "type": "number",
        "default": 200,
        "description": "每分钟阅读英文单词数，建议 150–250"
      },
      {
        "key": "label",
        "label": "标签文本",
        "type": "string",
        "default": "预计阅读",
        "description": "显示在阅读时间前面的文本，如\"预计阅读\"或\"Reading time\""
      },
      {
        "key": "unit",
        "label": "时间单位",
        "type": "string",
        "default": "分钟,或\"min\""
      },
      {
        "key": "less_than_one",
        "label": "不足一分钟文案",
        "type": "string",
        "default": "不足 1 分钟",
        "description": "阅读时间不足 1 分钟时显示的文字"
      },
      {
        "key": "position",
        "label": "注入位置",
        "type": "select",
        "default": "top",
        "options": [
          "top",
          "bottom"
        ],
        "description": "将阅读时间插入到内容顶部或底部"
      },
      {
        "key": "only_posts",
        "label": "仅文章生效",
        "type": "boolean",
        "default": true,
        "description": "关闭后，页面（page）类型也会显示阅读时间"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=neutral --format=iife --global-name=__plugin --footer:js=\"for(var __k in __plugin)this[__k]=__plugin[__k]\" --main-fields=browser,module,main --target=es2015 --outfile=dist/index.js",
    "build:watch": "esbuild src/index.ts --bundle --platform=neutral --format=cjs --main-fields=browser,module,main --target=es2015 --outfile=dist/index.js --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@nuxtblog/plugin-sdk": "^0.1.0",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2"
  }
}